.about-account-basics-card
  .card-header
    %h4.card-title
      %span.soft= t('about')
      = t('.title')
    %button.expand-toggle{ type: 'button', 'aria-label' => 'Expand about section' }
      %i.fa.fa-chevron-down
  .card-content
    .about-content-wrapper
      .col-md-5
        %ul
          %li= t('.first')
          %li= t('.second')
          %li= t('.third')
      .col-md-5
        %ul
          %li= t('.fourth')
          %li= t('.fifth')
