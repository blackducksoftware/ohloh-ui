- item_type ||= (@account ? 'Person' : 'ItemPage')
%div{ id: generate_page_name, itemscope: '', itemtype: "http://schema.org/#{item_type}" }
  .col-sm-12.col-md-12
    #page_contents= yield
  .clearfix
  - if responsive_layout && page_context[:footer_menu_list]
    .clearfix
    .footer-navigation
      = render 'layouts/partials/navigator'
  - elsif page_context[:footer_menu_list]
    .clearfix.margin_top_15
    .footer-navigation
      = render 'layouts/partials/navigator'
