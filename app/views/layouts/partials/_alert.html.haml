- key, klass = { error: 'alert-danger', notice: 'alert-info', success: 'alert-success', alert: 'alert-info' }.find { |k, _v| flash[k] }
- if key
  - icon = key == :error ? 'exclamation-circle' : (key == :success ? 'check-circle' : 'info-circle')
  #flash-msg
    .alert{ class: klass }
      .alert-accent-strip
      .alert-inner
        .flash-alert-icon
          %i{ class: "fa fa-#{icon}" }
        .flash-alert-content
          != flash[key]
        %button.close.flash-close{ type: 'button', 'aria-label' => 'Close' }
          %i.fa.fa-times
