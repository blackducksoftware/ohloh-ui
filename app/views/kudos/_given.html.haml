:ruby
  kudo_array = given.to_a
  first_kudo = kudo_array.delete_at(0)
  other_kudos = kudo_array

.kudos-item{ id: (first_kudo.account.nil? ? '' : "kudo_given_#{first_kudo.account.login}") }
  .kudos-item__avatar
    = avatar_tiny_laurels(kudo_rank_from_kudo(first_kudo))
  .kudos-item__body
    .kudos-item__name-row
      %span.kudos-item__name= kudo_person_link(first_kudo)
      - if kudo_is_new?(first_kudo.account_id, first_kudo.created_at)
        %span.kudos-item__new= t('kudos.new_link')
      - kudo_delete_link(first_kudo) if logged_in?
    - if first_kudo.project_id
      .kudos-item__project= t('kudos.for', what: first_kudo.project.name)
    - unless first_kudo.message.blank?
      .kudos-item__message &ldquo;#{first_kudo.message}&rdquo;
    - other_kudos.each do |kudo|
      .kudos-item__aka{ id: (first_kudo.account.nil? ? '' : "kudo_given_alternates_#{first_kudo.account.login}") }
        %span= t('.aka')
        = kudos_aka_name(kudo)
        - unless kudo.message.blank?
          .kudos-item__message &ldquo;#{kudo.message}&rdquo;
        - kudo_delete_link(kudo) if logged_in?
