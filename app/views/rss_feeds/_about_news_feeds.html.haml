.about-account-basics-card
  .card-header
    %h4.card-title
      %span.soft= t('.about_1')
      = t('.about_2')
    %button.expand-toggle{ type: 'button', 'aria-label' => 'Expand about section' }
      %i.fa.fa-chevron-down
  .card-content
    .about-content-wrapper
      .col-md-9
        %p= t('.about_txt')
        %p= t('.example')
        .col-md-9
          %ul.margin_left_25
            %li= t('.url_1')
            %li= t('.url_2')
            %li= t('.url_3')
