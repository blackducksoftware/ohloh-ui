- content_for :html_title do
  = t('.page_title', name: @project.name)

- page_context[:select_footer_nav] = :widgets

.project_content_title.margin_bottom_10{ style: 'height: 100%' }
  %h2 
    %strong= t('.widgets')
  %p
    = t('.embed')
    .clearfix
    .oh-card
      - @widgets.each do |widget|
        .project_widget_container
          = render partial: 'widget', locals: { widget: widget, type: 'project', ref: 'sample' }
