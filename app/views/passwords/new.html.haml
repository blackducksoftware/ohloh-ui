- content_for(:html_title) { t('passwords.title') }
- page_context[:suppress_flash] = true

.signup-page
  / ── Left Panel ──────────────────────────────────────────
  .signup-left-panel
    .signup-orb.signin-orb--top-left
    .signup-orb.signin-orb--bottom-right
    .signup-orb.signin-orb--center

    .signup-left-content
      .signup-badge
        .signup-badge__dot.signin-badge__dot--pulse
        Trusted by 890,000+ developers

      %h1.signup-headline
        Reset your
        %br
        %span.signup-headline__accent password

      %p.signup-tagline
        Enter your email address and we'll send you instructions to reset your password.

    .signup-benefits
      .signup-benefit
        .signup-benefit__icon.signin-feature--purple
          %i.fa.fa-code-fork
        .signup-benefit__text
          %p.signup-benefit__title 2.5M+ Open Source Projects
          %p.signup-benefit__desc Comprehensive data on millions of repositories worldwide.

      .signup-benefit
        .signup-benefit__icon.signin-feature--amber
          %i.fa.fa-users
        .signup-benefit__text
          %p.signup-benefit__title 890K Contributors
          %p.signup-benefit__desc Join a global community of open source developers.

      .signup-benefit
        .signup-benefit__icon.signin-feature--green
          %i.fa.fa-shield
        .signup-benefit__text
          %p.signup-benefit__title Security Intelligence
          %p.signup-benefit__desc Track risk scores and license compliance at a glance.

      .signup-benefit
        .signup-benefit__icon.signin-feature--pink
          %i.fa.fa-bolt
        .signup-benefit__text
          %p.signup-benefit__title Real-time Activity
          %p.signup-benefit__desc Live commit streams, PR activity, and release tracking.

    .signup-left-footer
      %p.signin-testimonial
        "Open Hub helped us assess the health of hundreds of dependencies before our major release."
      %p.signin-testimonial-attr
        — Engineering Lead, Fortune 500

  / ── Right Panel ─────────────────────────────────────────
  .signup-right-panel
    = render partial: 'layouts/partials/alert'
    .signup-form-card
      .signup-form-header
        %h2.signup-form-title Password Reset
        %p.signup-form-subtitle
          To be emailed a link to reset your password, please enter your email address.

      = form_for :password, url: passwords_path do |form|
        .signup-field-group
          %label.signup-field-label
            Email address
            %span.pwd-required *
          .signup-field-input-wrapper
            %i.fa.fa-envelope-o.signup-field-icon
            = form.email_field :email, class: 'signup-field-input', placeholder: 'you@example.com'

        .signup-field-actions
          = form.submit 'Reset password', class: 'signup-submit-btn'

      .pwd-reset-back
        = link_to new_session_path, class: 'signin-helper-link signin-helper-link--primary' do
          %i.fa.fa-arrow-left
          Back to Sign In

      .signup-terms-note
        Need help?
        = link_to 'Contact Support', 'mailto:info@openhub.net', class: 'signup-terms-link'
