- chart_url = commits_by_language_account_charts_url(@account, scope: 'regular').to_s
- light_wm = asset_url('charts/watermark_692.png')
- dark_wm  = asset_url('charts/watermark_692_dark.png')

.margin_top_10
  .pull-left#commits_lang
    %h4= link_to t('.link'), account_languages_path(@account)
  .pull-left.soft.margin_top_10.margin_left_20= chart_default_time_span
  .clearfix
.stream_graph.regular#ohloh_streamgraph{ 'datascope' => 'regular', 'datasrc' => chart_url, 'data-light-watermark' => light_wm, 'data-dark-watermark' => dark_wm }
