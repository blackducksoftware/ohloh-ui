- content_for(:html_title) { t('.page_title', name: @project.name) }
- page_context[:select_footer_nav] = :similar_projects

.similar-page
  .similar-page-header
    %h2.similar-page-title= t('.title')

  .similar-section
    %h3.similar-section-heading
      = pluralize_without_count(@similar_by_tags.length, t('.project'))
      = t('.similar_to')
      %span.similar-project-name= @project.name

    - if @similar_by_tags.any?
      .similar-grid
        - @similar_by_tags.each do |project|
          = render partial: 'similar_project', locals: { project: project }
    - else
      .similar-empty-state
        %p.similar-empty-text= t('.nothing_by_tags')
        %p.similar-empty-text
          = link_to t('.add_tags'), project_tags_path(@project), class: 'similar-action-link'
          = t('.to_similar')

  .similar-section
    %h3.similar-section-heading= t('.also_use', name: @project.name)

    - if @similar_by_stacks.any?
      .similar-grid
        - @similar_by_stacks.each do |project|
          = render partial: 'similar_project', locals: { project: project }
    - else
      .similar-empty-state
        %p.similar-empty-text= t('.nothing_by_stacks')
        %p.similar-empty-text.similar-muted= t('.nightly_update')
