      %h4= t('.news')
      %span.settings_description= t('.news_desc')

  %a.settings_module{ href: project_project_badges_path(@project) }
    .settings-icon-wrapper.gradient-amber
      %i.fa.fa-trophy
    .settings-text
      %h4= t('.badges')
      %span.settings_description= t('.badges_desc')
