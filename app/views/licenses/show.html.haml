- content_for(:html_title) { t('.title', name: @license.name) }

#license.oh-card.margin_top_20
  %h1.col-md-8.col-sm-6.col-xs-12.no_padding_left
    = link_to t('.license'), licenses_path
    &nbsp;:
    = link_to h(truncate(@license.name, length: 42)), license_url(@license), title: @license.name

  .col-md-4.col-sm-6.col-xs-12.licenses_button_groups.margin_top_20
    - if current_user_is_admin? || !@license.locked
      = link_to t('.edit_license'), edit_license_path(@license),
        class: "btn btn-info btn-md #{'needs_login' unless logged_in?}"

    = link_to t('.view_history'), license_edits_path(@license), class: 'btn btn-info btn-md'
    .margin_top_10
      = icon_button(@license.url, icon: 'external-link', text: t('.home_page'), size: 'md',
        type: 'info', target: '_blank', style: 'width: auto')

  .clearfix
  - if @license.description.blank?
    %p= link_to t('.provide_license'), edit_license_path(@license)

  - else
    %p.license-description= simple_format(html_escape(@license.description))

  - if @license.url.present?
    %p.license-url
      = t('.read_more')
      = link_to h(@license.url), h(@license.url)
  = link_to t('.add_new_license'), new_license_path, class: 'btn btn-lg btn-primary margin_bottom_20'
